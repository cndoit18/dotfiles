{{- /* User-level settings.local.json is private chezmoi input; Claude Code does not load it directly. */ -}}
{{- $claudeSettingsExtraPath := joinPath .chezmoi.homeDir ".claude" "settings.local.json" -}}
{{- $claudeSettingsExtra := dict -}}
{{- if stat $claudeSettingsExtraPath -}}
{{- $claudeSettingsExtra = include $claudeSettingsExtraPath | fromJson -}}
{{- end -}}
{{- $extraPermissions := dig "permissions" (dict) $claudeSettingsExtra -}}
{{- $extraEnv := dig "env" (dict) $claudeSettingsExtra -}}
{{- $extraEnabledPlugins := dig "enabledPlugins" (dict) $claudeSettingsExtra -}}
{{- $extraHooks := dig "hooks" (dict) $claudeSettingsExtra -}}
{
  "language": "chinese",
  "outputStyle": "Default",
  "permissions": {
    "allow": [
      {{- range dig "allow" (list) $extraPermissions }},
      {{ . | toJson }},
      {{- end }}
      "mcp__plugin_context7-plugin_context7__*",
      "Skill(commit-commands:*)",
      "Skill(cc-skills-golang:*)",
      "Skill(lark-*)",
      "Skill(python-development:*)",
      "Skill(deepwiki)",
      "Bash(obsidian:*)",
      "Skill(lark-skills:*)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "OPENAI_API_BASE": "{{ .ai.endpoint }}",
    "OPENAI_API_KEY": "{{ .ai.token }}",
    "REVIEW_MODEL": "{{ .ai.models.multimodal }}",
    "DEFAULT_MODEL": "{{ .ai.models.default }}",
    "IMAGE_MODEL": "{{ .ai.models.text2image }}"
    {{- range $key, $value := $extraEnv }},
    {{ $key | toJson }}: {{ $value | toJson }}
    {{- end }}
  },
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    {{- range $key, $value := $extraEnabledPlugins }},
    {{ $key | toJson }}: {{ $value | toJson }},
    {{- end }}
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "context7-plugin@context7": true,
    "agent-browser@agent-browser": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "cc-skills-golang@cc": true,
    "deepwiki@deepwiki": true,
    "python-development@agents": true,
    "obsidian@obsidian-skills": true,
    "lark-skills@lark-skills-for-claude-code": true,
    "understand-anything@Understand-Anything": true
  },
  "effortLevel": "high",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "hooks": {
    {{- range $event, $hooks := omit $extraHooks "PermissionRequest" "SessionStart" }}
    {{ $event | toJson }}: {{ $hooks | toJson }},
    {{- end }}
    "PermissionRequest": [
      {{- range dig "PermissionRequest" (list) $extraHooks }}
      {{ . | toJson }},
      {{- end }}
      {
        "matcher": "Read|Grep|Glob|Bash|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash {{ .chezmoi.homeDir }}/.claude/hooks/memory-palace-permission.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {{- range dig "SessionStart" (list) $extraHooks }}
      {{ . | toJson }},
      {{- end }}
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{ .chezmoi.homeDir }}/.claude/hooks/memory-palace.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "starship statusline claude-code"
  }
}
