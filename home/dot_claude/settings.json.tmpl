{
  "language": "chinese",
  "outputStyle": "Torvalds",
  "permissions": {
    "allow": [
      "mcp__plugin_context7-plugin_context7__*",
      "Skill(ui-ux-pro-max)",
      "Skill(skill-from-masters)",
      "Skill(scientific-schematics)",
      "Skill(async-python-patterns)",
      "Skill(drawio-diagrams-enhanced)",
      "Skill(mermaid)",
      "Skill(excalidraw)",
      "Skill(commit-commands:*)",
      "Skill(cc-skills-golang:*)",
      "Skill(python-development:*)"
    ]
  },
  "plansDirectory": "./.claude/plans",
  "alwaysThinkingEnabled": true,
  "env": {
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "OPENAI_API_BASE": "{{ .ai.endpoint }}",
    "OPENAI_API_KEY": "{{ .ai.token }}",
    "REVIEW_MODEL": "{{ .ai.models.multimodal }}",
    "DEFAULT_MODEL": "{{ .ai.models.default }}",
    "IMAGE_MODEL": "{{ .ai.models.text2image }}"
  },
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "context7-plugin@context7": true,
    "agent-browser@agent-browser": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "cc-skills-golang@cc": true,
    "python-development@agents": true
  },
  "effortLevel": "high",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{ .chezmoi.homeDir }}/.claude/hooks/project-detector.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
